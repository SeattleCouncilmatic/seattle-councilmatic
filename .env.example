# Councilmatic settings
OCD_CITY_COUNCIL_NAME="Seattle"

# Django settings
# In production: generate a real key with `python -c 'import secrets;
# print(secrets.token_urlsafe(64))'` and set DEBUG=False.
DJANGO_SECRET_KEY=your-very-secret-key-here
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
# Production-only — Django 4+ rejects state-changing POSTs from these
# origins as forged unless they're listed here. Caddy terminates TLS
# in front of gunicorn so the request looks plaintext to Django; this
# tells it the original origin was https. Comma-separated full
# origins (scheme + host).
# CSRF_TRUSTED_ORIGINS=https://www.seattlecouncilmatic.org,https://seattlecouncilmatic.org

# Database settings
# `postgres` resolves to the postgres container via Docker DNS in both
# the dev and prod compose files.
DATABASE_URL=postgis://postgres:postgres@postgres:5432/postgres
POSTGRES_REQUIRE_SSL=False
# Production-only — the postgres container creates the role and
# database with these values on first boot. The defaults in
# `docker-compose.prod.yml` are non-`postgres` (`councilmatic_app` /
# `councilmatic`) so a misconfigured `.env` doesn't silently fall
# back to the well-known superuser credentials. Override here to
# taste, but they MUST match what's embedded in `DATABASE_URL`:
#   DATABASE_URL=postgis://<POSTGRES_USER>:<POSTGRES_PASSWORD>@postgres:5432/<POSTGRES_DB>
# Changing post-first-boot requires manual `ALTER USER` /
# `ALTER DATABASE ... RENAME TO ...` SQL — see DEPLOY.md.
# POSTGRES_USER=councilmatic_app
# POSTGRES_DB=councilmatic
# POSTGRES_PASSWORD=replace-me-in-production

# Static files and media (for production)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1

# Search engine optimization
ALLOW_CRAWL=False

# Email settings (for notifications, if enabled)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=Seattle Councilmatic <noreply@seattlecouncilmatic.org>
#
# Pipeline health alerts (#210). check_pipeline_health emails these recipients
# when no successful full-cycle finishes within PIPELINE_HEARTBEAT_HOURS. Set the
# EMAIL_* vars above plus the recipients here to enable; without EMAIL_HOST the
# alert is logged (console backend) rather than emailed.
# PIPELINE_ALERT_EMAILS=ops@example.org,you@example.org
# PIPELINE_HEARTBEAT_HOURS=8
# PIPELINE_ALERT_RENOTIFY_HOURS=12

# Email digests (#231)
# Note: the signups launch gate / kill switch is NOT an env var — it's the
# "Digest configuration" checkbox in the Django admin (seeded open in dev,
# closed in prod). Phase 4 launch = tick the box.
# Transport for digest + verification email: "smtp" (default; reuses the
# EMAIL_* vars above — TEST-TO-SELF ONLY, never real subscribers) or
# "postmark" (production; wired in Phase 4).
# DIGEST_EMAIL_BACKEND=smtp
# DIGEST_FROM_EMAIL=Seattle Councilmatic <digests@seattlecouncilmatic.org>
# Secret for the HMAC manage/unsubscribe tokens. Falls back to
# DJANGO_SECRET_KEY when unset (fine for dev). In production, generate a
# dedicated value so token links can be rotated without killing sessions:
#   python -c 'import secrets; print(secrets.token_urlsafe(64))'
# SUBSCRIBER_TOKEN_SECRET=
# CAN-SPAM physical postal address, shown in every digest footer. Required
# before public launch (Phase 4).
# DIGEST_POSTAL_ADDRESS=

# Analytics (optional)
# GOOGLE_ANALYTICS_ID=GA-XXXXXXXX

# Sentry error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Claude API for plain-English summaries
ANTHROPIC_API_KEY=your-anthropic-api-key
# Model selection: the canonical per-pipeline defaults live in
# seattle_app/settings.py (CLAUDE_*_MODEL vars). Do NOT set these here just
# to mirror the defaults — set one only to deliberately pin this environment
# to a different model, and remove the pin when it's no longer needed. Stale
# mirror-pins are how prod quietly ran superseded models twice (see WORK_LOG
# "Prod .env can override settings.py model defaults").
# Available overrides, with their committed defaults:
#   CLAUDE_CODE_SECTION_MODEL=claude-sonnet-5       # SMC section summaries
#   CLAUDE_LEGISLATION_MODEL=claude-sonnet-5        # bill/ordinance analysis
#   CLAUDE_BILL_TAG_MODEL=claude-sonnet-5           # issue-area tagging
#   CLAUDE_REP_SUMMARY_MODEL=claude-sonnet-5        # councilmember cards
#   CLAUDE_EVENT_SUMMARY_MODEL=claude-sonnet-5      # meeting summaries
#   CLAUDE_COMMITTEE_SUMMARY_MODEL=claude-sonnet-5  # committee cards
#   CLAUDE_CHAT_MODEL=claude-sonnet-5               # interactive chatbot
#   CLAUDE_BOOTSTRAP_MODEL=claude-opus-4-8          # one-time few-shot calibration
